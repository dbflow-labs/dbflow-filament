{
  "name": "dbflowlabs/filament",
  "description": "Standard Filament integration package for DBFlow Core.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Baron Wang",
      "email": "hello@dbflow.dev"
    }
  ],
  "homepage": "https://github.com/dbflow-labs/dbflow-filament",
  "support": {
    "issues": "https://github.com/dbflow-labs/dbflow-filament/issues",
    "source": "https://github.com/dbflow-labs/dbflow-filament"
  },
  "autoload": {
    "psr-4": {
      "DbflowLabs\\Filament\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DbflowLabs\\Filament\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "dbflowlabs/core": "^0.2.0-alpha.1",
    "filament/filament": "^5.6"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "orchestra/testbench": "^11.0",
    "phpunit/phpunit": "^11.5.50"
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "extra": {
    "laravel": {
      "providers": [
        "DbflowLabs\\Filament\\Providers\\DBFlowFilamentServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  },
  "repositories": [
    {
      "name": "packagist",
      "type": "composer",
      "url": "https://repo.packagist.org"
    }
  ]
}
